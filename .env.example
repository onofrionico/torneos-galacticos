# Base de datos - Render te da esta URL automáticamente
DATABASE_URL=postgresql://usuario:password@host:5432/torneos_galacticos

# JWT - generá uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro_largo

# Servidor
PORT=3000
NODE_ENV=development

# Uploads - en Render usá un disco persistente o Cloudinary
UPLOADS_DIR=./public/uploads
MAX_FILE_SIZE_MB=100
